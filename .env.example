# Copy this file to .env locally and replace placeholder secrets.
# Do not commit real private keys or database passwords.

# API / server
ASCESWAP_POSTGRES_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Local only. On Railway, omit ASCESWAP_LISTEN_ADDR so the server binds to Railway's PORT.
ASCESWAP_LISTEN_ADDR="127.0.0.1:8080"
ASCESWAP_BOOTSTRAP_SCHEMA="true"
ASCESWAP_CHAIN_ID="421614"
ASCESWAP_EXCHANGE_ADDRESS="0x346457c948EaA86Afa9392B9E790bE2E42c6ebD6"

# Optional demo market maker. Use a separate funded testnet wallet.
ASCESWAP_DEMO_MM_PRIVATE_KEY="0xYOUR_DEMO_MARKET_MAKER_PRIVATE_KEY"
ASCESWAP_DEMO_MM_EPOCH="1"
ASCESWAP_DEMO_MM_MAX_FEE_RATE_BPS="100"
ASCESWAP_DEMO_MM_RESERVATION_TTL_SECS="30"
ASCESWAP_DEMO_MM_AUTO_COMMIT="false"

# Onchain executor / relayer
ASCESWAP_API_URL="http://127.0.0.1:8080"
ASCESWAP_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"
ASCESWAP_EXECUTOR_PRIVATE_KEY="0xYOUR_EXECUTOR_PRIVATE_KEY"
ASCESWAP_EXECUTOR_POLL_SECS="10"
ASCESWAP_EXECUTOR_RESERVATION_LIMIT="20"
ASCESWAP_EXECUTOR_CONFIRMATIONS="1"
ASCESWAP_EXECUTOR_DRY_RUN="false"
ASCESWAP_EXECUTOR_RELEASE_ON_SIMULATION_FAILURE="false"

# Oracle adapter keeper. Use a separate funded testnet wallet if possible.
ASCESWAP_KEEPER_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"
ASCESWAP_KEEPER_PRIVATE_KEY="0xYOUR_ADAPTER_KEEPER_PRIVATE_KEY"
ASCESWAP_KEEPER_CHAIN_ID="421614"
ASCESWAP_KEEPER_INTERVAL_SECS="300"
ASCESWAP_KEEPER_RETRY_SECS="60"
ASCESWAP_KEEPER_CONFIRMATIONS="1"
ASCESWAP_KEEPER_DRY_RUN="false"
ASCESWAP_KEEPER_TARGETS="aave-usdc-borrow=0x3B9D6fF6d0C798317f3B51681e335f5b07cbD70F:0x2f56d7c26e665a04dd24404cdd841d6fcd7fd402a3b127760e2598c64d2df369;arbitrum-gas=0x81aA57736801E33f8ef059F79B8F4332416D4DB8:0xfe77931a0aa6baee55370819b38cb10feb3f03e2c0053a9a37e3213a471b7f28"
